<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="15dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.cardview.widget.CardView
        android:layout_marginStart="10dp"
        android:id="@+id/cardViewReview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:cardElevation="0dp"
        app:cardCornerRadius="50dp"

        >

        <ImageView
            android:id="@+id/ivUserImageReview"
            android:layout_width="50dp"
            android:layout_height="50dp"
            />

    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvReviewUserName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@id/cardViewReview"
        app:layout_constraintStart_toEndOf="@id/cardViewReview"
        android:layout_marginStart="70dp"
        android:layout_marginEnd="100dp"
        android:text="User Name"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@color/text_app_color"
        />


    <RatingBar
        android:id="@+id/ratingBarRv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvReviewUserName"
        android:layout_marginStart="15dp"
        android:scaleX="0.5"
        android:scaleY="0.5"
        android:progressTint="#FFEB3B"
        />


    <TextView
        android:id="@+id/tvReviewDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@id/tvReviewUserName"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="15dp"
        android:textSize="14sp"
        android:text="12/05/2024"
        />

    <TextView
        android:id="@+id/tvReviewContent"
        android:layout_width="match_parent"
        android:layout_marginStart="70dp"
        android:layout_marginEnd="20dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="@id/tvReviewUserName"
        app:layout_constraintTop_toBottomOf="@id/tvReviewUserName"
        android:layout_marginTop="40dp"
        android:textColor="@color/text_app_color"
        android:textSize="16sp"
        android:text="Content ..."

        />


</androidx.constraintlayout.widget.ConstraintLayout>